<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Budget Cache – Ramonify</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f4f6fb; color: #1a1a2e; min-height: 100vh; }
    nav { background: #2e4a7a; padding: 0 2rem; display: flex; align-items: center; gap: 2rem; height: 56px; }
    nav .brand { font-size: 1.2rem; font-weight: 700; color: #fff; text-decoration: none; }
    nav a { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.9rem; padding: 4px 0; border-bottom: 2px solid transparent; }
    nav a:hover, nav a.active { color: #fff; border-bottom-color: #7eb3ff; }
    .container { max-width: 860px; margin: 2.5rem auto; padding: 0 1.5rem; }
    h1 { font-size: 1.6rem; font-weight: 700; color: #2e4a7a; margin-bottom: 0.3rem; }
    .subtitle { color: #666; font-size: 0.88rem; margin-bottom: 1.8rem; }
    .card { background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.07); margin-bottom: 1.5rem; }
    .card h2 { font-size: 0.95rem; font-weight: 700; color: #2e4a7a; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #eef0f6; }
    .form-row { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: flex-end; }
    .form-group { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 120px; }
    label { font-size: 0.75rem; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.4px; }
    input { padding: 8px 12px; border: 1px solid #dde1ee; border-radius: 8px; font-size: 0.9rem; background: #fafbff; color: #1a1a2e; width: 100%; }
    input:focus { outline: none; border-color: #4472c4; }
    .btn { padding: 8px 18px; border: none; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: opacity 0.15s; white-space: nowrap; }
    .btn:hover { opacity: 0.85; }
    .btn-primary { background: #2e4a7a; color: #fff; }
    .btn-success { background: #2e7a4a; color: #fff; }
    .btn-warning { background: #e8a020; color: #fff; }
    .btn-danger  { background: #c0392b; color: #fff; }
    .btn-sm { padding: 5px 12px; font-size: 0.78rem; }
    .user-switcher { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .user-switcher span { font-size: 0.85rem; color: #555; }
    .user-switcher a { padding: 5px 14px; border-radius: 20px; font-size: 0.82rem; font-weight: 600; text-decoration: none; background: #eef0f6; color: #2e4a7a; border: 2px solid transparent; }
    .user-switcher a.active { background: #2e4a7a; color: #fff; }
    table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    th { background: #f0f3fb; color: #2e4a7a; font-weight: 600; padding: 10px 14px; text-align: left; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.4px; }
    td { padding: 10px 14px; border-bottom: 1px solid #f0f0f5; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafbff; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .badge-danger  { background: #fdecea; color: #c0392b; }
    .badge-warning { background: #fef6e4; color: #b07800; }
    .badge-success { background: #eafaf1; color: #1e6e3b; }
    .empty { text-align: center; padding: 2rem; color: #aaa; font-size: 0.9rem; }
    .actions { display: flex; gap: 6px; }
    .bar-wrap { background: #eef0f6; border-radius: 20px; height: 8px; width: 120px; }
    .bar { height: 8px; border-radius: 20px; max-width: 100%; }
    .mono { font-family: monospace; font-size: 0.82rem; color: #555; background: #f4f6fb; padding: 2px 6px; border-radius: 4px; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="brand">💰 Ramonify</a>
    <a href="/sessions">Sessions</a>
    <a href="/budget" class="active">Budget Cache</a>
    <a href="/top-categories">Top Categories</a>
  </nav>

  <div class="container">
    <h1>📊 Budget Status Cache</h1>
    <p class="subtitle">Redis Sorted Set — key: budgetStatus:userId — score: % of budget consumed</p>

    <!-- User switcher -->
    <div class="user-switcher">
      <span>Viewing user:</span>
      <% ['42','7','15'].forEach(uid => { %>
        <a href="/budget?userId=<%= uid %>" class="<%= userId === uid ? 'active' : '' %>">User <%= uid %></a>
      <% }) %>
    </div>

    <!-- CREATE -->
    <div class="card">
      <h2>Add Category Budget Score — CREATE</h2>
      <form action="/budget" method="POST">
        <input type="hidden" name="userId" value="<%= userId %>" />
        <div class="form-row">
          <div class="form-group">
            <label>Category</label>
            <input type="text" name="category" placeholder="e.g. Groceries" required />
          </div>
          <div class="form-group">
            <label>% Consumed (0–100+)</label>
            <input type="number" name="score" placeholder="e.g. 85" step="0.1" required />
          </div>
          <button type="submit" class="btn btn-primary">Add</button>
        </div>
      </form>
    </div>

    <!-- READ -->
    <div class="card">
      <h2>Categories Ranked by Budget Urgency — READ &nbsp;<span class="mono">budgetStatus:<%= userId %></span></h2>
      <% if (entries.length === 0) { %>
        <div class="empty">No budget data for user <%= userId %>. Add a category above.</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>Category</th>
              <th>% Consumed</th>
              <th>Progress</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% entries.forEach((e, i) => {
                const pct = parseFloat(e.score);
                const barColor = pct >= 100 ? '#c0392b' : pct >= 80 ? '#e8a020' : '#2e7a4a';
                const badge = pct >= 100 ? 'badge-danger' : pct >= 80 ? 'badge-warning' : 'badge-success';
                const label = pct >= 100 ? 'Over Budget' : pct >= 80 ? 'At Risk' : 'Under Budget';
            %>
              <tr>
                <td><strong>#<%= i + 1 %></strong></td>
                <td><%= e.value %></td>
                <td><strong><%= pct.toFixed(1) %>%</strong></td>
                <td>
                  <div class="bar-wrap">
                    <div class="bar" style="width:<%= Math.min(pct, 100) %>%; background:<%= barColor %>;"></div>
                  </div>
                </td>
                <td><span class="badge <%= badge %>"><%= label %></span></td>
                <td>
                  <div class="actions">
                    <form action="/budget/delete" method="POST">
                      <input type="hidden" name="userId" value="<%= userId %>" />
                      <input type="hidden" name="category" value="<%= e.value %>" />
                      <button class="btn btn-danger btn-sm">Remove</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <!-- UPDATE -->
    <div class="card">
      <h2>Log a Transaction — UPDATE (ZINCRBY)</h2>
      <form action="/budget/increment" method="POST">
        <input type="hidden" name="userId" value="<%= userId %>" />
        <div class="form-row">
          <div class="form-group">
            <label>Category</label>
            <input type="text" name="category" placeholder="e.g. Groceries" required />
          </div>
          <div class="form-group">
            <label>Increment % by</label>
            <input type="number" name="amount" placeholder="e.g. 10" step="0.1" required />
          </div>
          <button type="submit" class="btn btn-success">Increment Score</button>
        </div>
      </form>
    </div>

    <!-- DELETE ALL -->
    <div class="card">
      <h2>Clear All Budget Data — DELETE</h2>
      <form action="/budget/clear" method="POST">
        <input type="hidden" name="userId" value="<%= userId %>" />
        <button type="submit" class="btn btn-danger" onclick="return confirm('Clear all budget data for user <%= userId %>?')">
          Clear All for User <%= userId %>
        </button>
      </form>
    </div>

  </div>
</body>
</html>
